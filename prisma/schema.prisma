// Ableverse – Prisma schema (Prisma 7)
// MVP: crowdsourced accessibility ratings for District 7 / Sky Garden pilot

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Venues cached from Google Places API
model Venue {
  id            String   @id @default(uuid())
  googlePlaceId String   @unique @map("google_place_id")
  name          String
  address       String
  lat           Float
  lng           Float
  photoUrl      String?  @map("photo_url")
  category      String   @default("cafe")
  createdAt     DateTime @default(now()) @map("created_at")

  ratings AccessibilityRating[]

  @@map("venues")
}

// Extends Supabase auth.users
model Profile {
  id             String   @id
  displayName    String?  @map("display_name")
  phone          String?
  disabilityType String?  @map("disability_type")
  role           String   @default("community") // 'team' | 'community'
  createdAt      DateTime @default(now()) @map("created_at")

  ratings AccessibilityRating[]

  @@map("profiles")
}

// One submission per user per venue (6-item checklist)
// Values: 'yes' | 'no' | 'unsure'  (enforced via CHECK in seed SQL)
model AccessibilityRating {
  id                 String   @id @default(uuid())
  venueId            String   @map("venue_id")
  venue              Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  ratedBy            String   @map("rated_by")
  profile            Profile  @relation(fields: [ratedBy], references: [id])
  raterType          String   @default("community") @map("rater_type") // 'team' | 'community'
  verified           Boolean  @default(false)

  entrance           String   // step-free entrance / ramp
  walkwayDoorWidth   String   @map("walkway_door_width") // wheelchair can pass
  accessibleRestroom String   @map("accessible_restroom")
  tableSeating       String   @map("table_seating") // open-underneath table available
  parking            String   // accessible parking near entrance

  photoProofUrl      String?  @map("photo_proof_url") // optional, Supabase Storage
  note               String?
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("accessibility_ratings")
}
